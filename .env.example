# Copy this file to ".env" and fill in your real values, then restart `npm run dev`.
# (.env is gitignored so your keys stay private.)

# --- Supabase (accounts / login) ---
# Create a free project at https://supabase.com, then find these under
# Project Settings → API. Enable Email auth under Authentication → Providers.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# --- Web3Forms (enquiry & quote emails) ---
# Get a free access key at https://web3forms.com using enquiry@caribvestio.com
# as the destination inbox. Paste it here.
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
